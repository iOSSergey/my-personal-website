# Example environment file for iossergey.online
# Copy this file to client_management_system.env and update the values

# Server configuration
SERVER_NAME=iossergey.online

# Django settings
DEBUG=False
SECRET_KEY=your-secret-key-here

# Database configuration
DATABASE_NAME=your_database_name
DATABASE_USER=your_database_user
DATABASE_PASSWORD=your_database_password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Security settings
ALLOWED_HOSTS=iossergey.online,www.iossergey.online
CSRF_TRUSTED_ORIGINS=https://iossergey.online,https://www.iossergey.online